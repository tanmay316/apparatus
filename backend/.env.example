# Apparatus AI Nutrition Backend - Environment Variables
# Copy this file to .env and fill in your values

# Database (use SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./apparatus.db
# DATABASE_URL=postgresql://user:password@host:5432/apparatus

# Firebase Service Account (JSON string for Railway, or path)
FIREBASE_SERVICE_ACCOUNT_JSON=

# AI Provider API Keys
NVIDIA_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# CORS
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
